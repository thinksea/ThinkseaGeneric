/*
	文件功能：编译 TypeScript 代码的基本设置
	1、编译所有 .ts 文件为 .js 文件
	2、不保留注释，尽可能减小输出的 .js 文件大小
*/
{
  "compileOnSave": true, //当保存 TypeScript 文件时立即编译。
  "compilerOptions": {
    "strict": true, //是否启用严格模式
    "noImplicitAny": false, //不允许变量或函数参数具有隐式 any 类型。
    //"noImplicitThis": false, //不允许 this 上下文隐式定义。
    //"strictNullChecks": false, //不允许出现 null 或 undefined 的可能性。
    //"strictPropertyInitialization": false, //验证构造函数内部初始化前后已定义的属性。
    //"strictBindCallApply": false, //对 bind, call, apply 更严格的类型检测。
    //"strictFunctionTypes": false //对函数参数进行严格逆变比较。
    "noEmitOnError": true, //出错后，不输出文件。默认值false
    "removeComments": true, //去除注释。默认值false
    "stripInternal": false, // 保留 @internal 注释
    "sourceMap": true, //生成对应的 map 文件。默认值false
    "target": "es6", //指定生成代码的 ECMAScript 版本。默认值"es3"。有效取值范围："es3" | "es5" | "es6" | "es2015" | "es2016" | "es2017" | "es2018" | "es2019" | "es2020" | "es2021" | "es2022" | "es2023" | "esnext"
    //"module": null, //指定生成代码时使用的模块系统。默认值: 取决于 target，通常为 commonjs。有效取值范围："none" | "commonjs" | "amd" | "system" | "umd" | "esnext" | "es6" | "es2015" | "node16" | "nodenext"
    "emitBOM": true, //在输出文件头添加 utf-8 (BOM)字节标记。默认值false
    "declaration": false //指示是否生成 d.ts 文件
  }
}
