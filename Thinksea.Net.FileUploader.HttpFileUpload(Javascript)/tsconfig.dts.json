/*
	文件功能：仅为部分 ts 文件生成 TypeScript 声明文件（.d.ts），并且保留注释。
	要求：
	1、安装 TypeScript 编译器
	【指令】npm install typescript --save-dev
	2、执行 TypeScript 编译设置文件 tsconfig.dts.json
	2.1、在工程文件（ERP.csproj）中增加下面的设置：
	<Target Name="GenerateErpAPIDeclaration" AfterTargets="Build">
		<!-- 在编译项目后生成.d.ts（TypeScript 声明文件），调用为生成d.ts创建的专用配置文件 -->
		<Exec Command="npx tsc --project tsconfig.dts.json" />
	</Target>
	2.2、或者执行下面的指令：
	【指令】：npx tsc --project tsconfig.dts.json
*/
{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"removeComments": false, // 重要：不移除注释
		"declaration": true, // 指示是否生成 d.ts 文件
		"declarationMap": false, // 可选：生成声明映射
		"emitDeclarationOnly": true // 只生成声明文件
	},
	"include": [
    "wwwroot/lib/dts/**/*.d.ts", // 包含声明文件
    "wwwroot/ts/**/*.ts" //指定要编译的文件或目录。默认值: ["**/*"]
	]
}
